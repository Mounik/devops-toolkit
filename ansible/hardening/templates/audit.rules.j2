# Auditd rules template - CIS Benchmark compliant
# Monitor critical system files and privileged operations

# Delete all existing rules
-D

# Buffer size
-b 8192
-f 4

# Login/logout
-w /var/log/faillog -p wa -k logins
-w /var/log/lastlog -p wa -k logins
-w /var/log/tallylog -p wa -k logins

# User/group modifications
-w /etc/group -p wa -k identity
-w /etc/passwd -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/security/opasswd -p wa -k identity

# Sudo
-w /etc/sudoers -p wa -k sudo
-w /etc/sudoers.d/ -p wa -k sudo

# SSH
-w /etc/ssh/sshd_config -p wa -k sshd

# Systemd
-w /etc/systemd/system/ -p wa -k systemd

# Cron
-w /etc/cron.allow -p wa -k cron
-w /etc/cron.deny -p wa -k cron
-w /etc/cron.d/ -p wa -k cron
-w /etc/cron.daily/ -p wa -k cron
-w /etc/cron.hourly/ -p wa -k cron
-w /etc/cron.weekly/ -p wa -k cron
-w /etc/cron.monthly/ -p wa -k cron

# Network
-a exit,always -F arch=b64 -S sethostname -k network
-w /etc/hosts -p wa -k network
-w /etc/resolv.conf -p wa -k network

# Kernel modules
-a always,exit -F arch=b64 -S init_module -S delete_module -k modules

# Mount operations
-a always,exit -F arch=b64 -S mount -S umount2 -k mount

# Privileged commands
-a always,exit -F arch=b64 -S chown -S chmod -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b64 -S unlink -S rename -S rmdir -F auid>=1000 -F auid!=4294967295 -k delete

# Failed access attempts
-a always,exit -F arch=b64 -S open -F exit=-EACCES -F auid>=1000 -F auid!=4294967295 -k access
-a always,exit -F arch=b64 -S open -F exit=-EPERM -F auid>=1000 -F auid!=4294967295 -k access